# Gmail OAuth credentials (download from Google Cloud Console)
GMAIL_CREDENTIALS_FILE=credentials.json
GMAIL_TOKEN_FILE=token.json

# Candidate info for email drafts
CANDIDATE_NAME=Dr. Jane Doe
CANDIDATE_EMAIL=jane.doe@email.com
SENDER_NAME=John Doe
SENDER_EMAIL=john.doe@gmail.com

# Google Custom Search API (optional - for hospital discovery)
GOOGLE_API_KEY=
GOOGLE_CSE_ID=

# Rate limiting (seconds between requests)
REQUEST_DELAY=2.0

# Max jobs to fetch per source per run
MAX_JOBS_PER_SOURCE=200
